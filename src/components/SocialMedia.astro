<section class="social-media">
  <div class="container">
    <div class="social-cards">
      <div class="social-card facebook">
        <div class="social-icon facebook-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="#1877F2">
            <path d="M13.397 20.997v-8.196h2.765l.411-3.209h-3.176V7.548c0-.926.258-1.56 1.587-1.56h1.684V3.127A22.336 22.336 0 0014.201 3c-2.444 0-4.122 1.492-4.122 4.231v2.355H7.332v3.209h2.753v8.202h3.312z"/>
          </svg>
        </div>
        <h3>Síguenos en Facebook</h3>
        <p>Mantente al día con nuestras últimas novedades y promociones</p>
        <a href="https://www.facebook.com/enrines?_rdc=1&_rdr#" target="_blank" class="social-link">Visitar página</a>
      </div>
      
      <div class="social-card instagram">
        <div class="social-icon instagram-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24">
            <defs>
              <radialGradient id="ig-gradient" cx="0.35" cy="0.35" r="1.2">
                <stop offset="0%" stop-color="#fd5949"/>
                <stop offset="50%" stop-color="#d6249f"/>
                <stop offset="100%" stop-color="#285AEB"/>
              </radialGradient>
            </defs>
            <path fill="url(#ig-gradient)" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </div>
        <h3>Síguenos en Instagram</h3>
        <p>Descubre nuestros trabajos más recientes</p>
        <a href="https://www.instagram.com/enrines?igsh=dHk1Y2ljdmt5bGQ5" target="_blank" class="social-link">Visitar perfil</a>
      </div>
    </div>
  </div>

  <script>
    if (typeof window !== "undefined") {
      const totalImages = 5;
      const daysSinceEpoch = Math.floor(Date.now() / (1000 * 60 * 60 * 24));
      
      const fbIndex = (Math.floor(daysSinceEpoch / 30) % totalImages) + 1;
      const igIndex = (Math.floor((daysSinceEpoch + 15) / 30) % totalImages) + 6;
  
      const facebookCard = document.querySelector('.social-card.facebook');
      const instagramCard = document.querySelector('.social-card.instagram');
  
      const fbImageUrl = `/images/gallery${fbIndex}.png`;
      const igImageUrl = `/images/gallery${igIndex}.png`;
      if (facebookCard) {
        (facebookCard as HTMLElement).style.background = `
          linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
          url('${fbImageUrl}')
        `;
        (facebookCard as HTMLElement).style.backgroundSize = 'cover';
        (facebookCard as HTMLElement).style.backgroundPosition = 'center';
      }
  
      if (instagramCard) {
        (instagramCard as HTMLElement).style.background = `
          linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)),
          url('${igImageUrl}')
        `;
        (instagramCard as HTMLElement).style.backgroundSize = 'cover';
        (instagramCard as HTMLElement).style.backgroundPosition = 'center';
      }
    }
  </script>
</section>

<style>
  .social-media {
    padding: 4rem 0;
    background-color: var(--color-black);
  }

  .social-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .social-card {
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    transition: transform 0.3s ease;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
  }

  .social-card:hover {
    transform: translateY(-10px);
  }

  .social-icon svg {
    width: 48px;
    height: 48px;
  }

  .social-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--color-white);
  }

  .social-card p {
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.5;
  }

  .social-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: transparent;
    border: 2px solid var(--color-white);
    border-radius: 6px;
    color: var(--color-white);
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background-color: var(--color-white);
    color: var(--color-black);
  }

  @media (max-width: 768px) {
    .social-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
