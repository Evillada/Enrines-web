---
import LogoImg from '../assets/logo.png';
---
<header class="header">
  <div class="container">
    <div class="header-content">
      <!-- Logo alineado a la izquierda -->
      <a href="/" class="logo">
        <img src="/images/logo.png" alt="Enrines ICOR Logo" width="150" height="60" />
      </a>

      <!-- Menú + Logo Antioquia + WhatsApp alineados a la derecha --> 
      <div class="right-nav">
        <nav class="desktop-nav">
          <ul>
            <!-- <li><a href="#servicios">SERVICIOS</a></li> -->
            <li><a href="#galeria">GALERÍA</a></li>
            <li><a href="#contacto">CONTACTO</a></li>
          </ul>
        </nav>

        <!-- Logo de Antioquia -->
        <div class="antioquia-badge">
          <div class="antioquia-content">
            <div class="antioquia-flag">
              <div class="flag-stripe white"></div>
              <div class="flag-stripe green"></div>
            </div>
            <span class="antioquia-text">
              ADN
              <span class="antioquia-dna"> Antioqueño</span>
            </span>
          </div>
        </div>

