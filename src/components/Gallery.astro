---
import { readdirSync } from 'fs';
import { resolve } from 'path';

const imagesDir = resolve('./public/images');
const galleryNums = readdirSync(imagesDir)
  .filter(f => /^gallery\d+\.png$/i.test(f))
  .map(f => parseInt(f.match(/(\d+)/)![0]))
  .sort((a, b) => a - b);
---

