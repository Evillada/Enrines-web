  <div class="gallery-modal">
    <div class="gallery-modal-content">
      <button class="gallery-modal-close">&times;</button>
      <img src="" alt="Imagen Ampliada" class="gallery-modal-image" />
    </div>
  </div>
  
  <script define:vars={{ galleryNums }}>
    // Rotación de imágenes cada 6 horas (ventana deslizante)
    var DISPLAY_COUNT = 6;
    var sixHourPeriods = Math.floor(Date.now() / (1000 * 60 * 60 * 6));
    var startIdx = sixHourPeriods % galleryNums.length;

    var imgs = document.querySelectorAll('.gallery-image');
    imgs.forEach(function(img, i) {
      var num = galleryNums[(startIdx + i) % galleryNums.length];
      img.src = '/images/gallery' + num + '.png';
    });

    // Modal
    var galleryItems = document.querySelectorAll('.gallery-item');
    var galleryModal = document.querySelector('.gallery-modal');
    var galleryModalImage = document.querySelector('.gallery-modal-image');
    var galleryModalClose = document.querySelector('.gallery-modal-close');

    galleryItems.forEach(function(item) {
      item.addEventListener('click', function() {
        var img = item.querySelector('img');
        if (!img || !galleryModalImage || !galleryModal) return;
        galleryModalImage.src = img.src;
        galleryModal.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    if (galleryModalClose) {
      galleryModalClose.addEventListener('click', function() {
        galleryModal.classList.remove('active');
        document.body.style.overflow = '';
      });
    }

    if (galleryModal) {
      galleryModal.addEventListener('click', function(e) {
        if (e.target === galleryModal) {
          galleryModal.classList.remove('active');
          document.body.style.overflow = '';
        }
      });
    }
  </script>
  
  <style>
    .gallery {
      background-color: var(--color-black);
      padding: 5rem 0;
    }
    
    .gallery-description {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 3rem;
      color: rgba(255, 255, 255, 0.7);
      font-size: 1.1rem;
      line-height: 1.6;
    }
    
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
    
    .gallery-item {
      position: relative;
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      aspect-ratio: 16/9;
    }
    
    .gallery-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }
    
    .gallery-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    
    .gallery-icon {
      width: 50px;
      height: 50px;
      background-color: var(--color-red);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--color-white);
      transform: scale(0.8);
      transition: transform 0.3s ease;
    }
    
    .gallery-item:hover .gallery-overlay {
      opacity: 1;
    }
    
    .gallery-item:hover .gallery-icon {
      transform: scale(1);
    }
    
    .gallery-item:hover .gallery-image {
      transform: scale(1.1);
    }
    
    .gallery-modal {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.9);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1001;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.3s ease, visibility 0.3s ease;
    }
    
    .gallery-modal.active {
      opacity: 1;
      visibility: visible;
    }
    
    .gallery-modal-content {
      position: relative;
      max-width: 90%;
      max-height: 90%;
    }
    
    .gallery-modal-image {
      display: block;
      max-width: 100%;
      max-height: 90vh;
      border-radius: 4px;
    }
    
    .gallery-modal-close {
      position: absolute;
      top: -40px;
      right: 0;
      font-size: 2rem;
      color: var(--color-white);
      background: transparent;
      border: none;
      cursor: pointer;
    }
    
    @media (max-width: 992px) {
      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (max-width: 576px) {
      .gallery-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>