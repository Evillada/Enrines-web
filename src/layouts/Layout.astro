---
import Header from '../components/Header.astro';
import FloatingButtons from '../components/FloatingButtons.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Enrines ICOR — especialistas en reparación, enderezada, pintura y venta de rines y llantas en Medellín. Alineación y balanceo profesional. Cra 43G #26A-38, Medellín.',
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "name": "Enrines ICOR",
  "description": "Taller especializado en reparación, enderezada, pintura y venta de rines y llantas en Medellín. Servicio de alineación y balanceo.",
  "url": "https://enrines-icor.com",
  "telephone": "+573152713602",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Cra 43G #26 A 38",
    "addressLocality": "Medellín",
    "addressRegion": "Antioquia",
    "addressCountry": "CO"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 6.2442,
    "longitude": -75.5812
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "17:30"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:30",
      "closes": "12:30"
    }
  ],
  "sameAs": [
    "https://www.facebook.com/enrines",
    "https://www.instagram.com/enrines"
  ],
  "priceRange": "$$",
  "image": "https://enrines-icor.com/images/hero.jpg"
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO primario -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://enrines-icor.com" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://enrines-icor.com" />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://enrines-icor.com/images/hero.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Enrines ICOR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://enrines-icor.com/images/hero.jpg" />

    <!-- Datos estructurados LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <FloatingButtons />
  </body>
</html>

<style is:global>
  :root {
    --color-black: #000000;
    --color-red: #FF3A3A;
    --color-dark-red: #c42828;
    --color-white: #FFFFFF;
    --color-gray: #303030;
    --color-light-gray: #f0f0f0;
  }
  
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  html {
    font-family: 'Roboto', sans-serif;
    scroll-behavior: smooth;
  }
  
  body {
    background-color: var(--color-black);
    color: var(--color-white);
    min-height: 100vh;
    overflow-x: hidden;
  }
  
  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  
  a {
    color: inherit;
    text-decoration: none;
  }
  
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .btn-primary {
    background-color: var(--color-red);
    color: var(--color-white);
  }
  
  .btn-primary:hover {
    background-color: var(--color-dark-red);
  }
  
  .section-title {
    text-align: center;
    margin-bottom: 2rem;
    position: relative;
  }
  
  .section-title h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }
  
  .section-title h2 span {
    color: var(--color-red);
  }
  
  .section-title::after {
    content: '';
    display: block;
    width: 80px;
    height: 3px;
    background-color: var(--color-red);
    margin: 1rem auto 0;
  }
  
  section {
    padding: 4rem 0;
  }
  
  @media (max-width: 768px) {
    .section-title h2 {
      font-size: 2rem;
    }
    
    section {
      padding: 3rem 0;
    }
  }
</style>